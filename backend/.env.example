# =====================================================
# Finsped Express — Environment Configuration Example
# =====================================================
# Copy file ini menjadi .env dan isi nilai sesuai environment.
# JANGAN commit file .env ke repository.

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=accountech_db

# --- Server ---
PORT=5000

# --- Auth ---
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_strong_random_secret

# --- Security ---
# Matikan register publik di produksi. Akun hanya dibuat Admin Sistem.
# Set "true" hanya untuk development/seed awal.
ALLOW_PUBLIC_REGISTER=false
